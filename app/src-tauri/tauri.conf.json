{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "plan-up",
  "version": "../package.json",
  "identifier": "com.planup.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "plan-up",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 14,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg"
    ],
    "icon": [
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEMkQ4M0RCMDg0RDUyMDUKUldRRlVrMEkyNE10UFgwa3gxbXdwNlh0aW4vMTUvcHNEM05DT0U3L1VQQzZKSWJJNjF4RmNCWGEK",
      "endpoints": [
        "https://github.com/tunghipz/plan-up/releases/latest/download/latest.json"
      ]
    }
  }
}
